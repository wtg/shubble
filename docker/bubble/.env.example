# Bubble AI Agent — environment variables

# Database connection (same as backend/worker)
DATABASE_URL=postgresql://shubble:shubble@postgres:5432/shubble

# Redis connection (same as backend/worker)
REDIS_URL=redis://redis:6379/0

# Google Gemini API key (required)
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model to use (default: gemini-2.0-flash-lite)
BUBBLE_MODEL=gemini-2.0-flash-lite

# Base URL of the Shubble backend (used to fetch live shuttle location data)
# In Docker Compose this is typically http://backend:8000
BACKEND_URL=http://backend:8000

# Comma-separated list of URLs to fetch as context for announcement generation
# Examples: weather APIs, campus event feeds, road closure feeds
# Leave empty to generate announcements with no external data
BUBBLE_SOURCES=

# How often Bubble regenerates announcements, in seconds (default: 3600 = 1 hour)
BUBBLE_INTERVAL=3600

# Logging level (debug, info, warning, error)
LOG_LEVEL=info

# Override log level specifically for Bubble (optional; falls back to LOG_LEVEL)
# BUBBLE_LOG_LEVEL=debug
