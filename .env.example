# =============================================================================
# SHUBBLE ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update with your values

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://shubble:shubble@localhost:5432/shubble

# =============================================================================
# REDIS CACHE
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# APPLICATION
# =============================================================================
DEBUG=true
LOG_LEVEL=INFO
DEPLOY_MODE=development

# =============================================================================
# SERVICE URLS
# =============================================================================
FRONTEND_URLS=http://localhost:3000
BACKEND_URL=http://localhost:8000
TEST_FRONTEND_URL=http://localhost:5174
TEST_BACKEND_URL=http://localhost:4000

# =============================================================================
# API KEYS & SECRETS
# =============================================================================
# Samsara API key (leave empty to use test-server mock API)
API_KEY=

# Samsara webhook secret (base64 encoded)
SAMSARA_SECRET=

# Apple MapKit JS token
MAPKIT_KEY=

# =============================================================================
# BUBBLE (AI ANNOUNCEMENT AGENT)
# =============================================================================
# Google Gemini API key — obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model to use (default: gemini-2.0-flash-lite)
BUBBLE_MODEL=gemini-3-flash-preview

# Comma-separated list of URLs Bubble fetches as context for announcement generation
# (e.g. weather APIs, campus event feeds, road closure feeds)
BUBBLE_SOURCES=

# How often Bubble regenerates announcements, in seconds (default: 3600 = 1 hour)
BUBBLE_INTERVAL=300
